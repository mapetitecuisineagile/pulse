generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Tribe {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  color       String   @default("#7b61ff")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  teams       Team[]
}

model Team {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  trigram             String
  color               String   @default("#2E75B6")
  description         String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  tribe               Tribe?   @relation(fields: [tribeId], references: [id])
  tribeId             String?
  sprintDurationWeeks Int      @default(3)
  pctBau              Float    @default(0.30)
  pctRisk             Float    @default(0.10)
  pctCerem            Float    @default(0)
  pctOther            Float    @default(0)
  predMode            String   @default("sp")
  members             Member[]
  sprints             Sprint[]
}


model Member {
  id                String    @id @default(cuid())
  team              Team      @relation(fields: [teamId], references: [id])
  teamId            String
  firstName         String
  lastName          String
  role              String
  fte               Float     @default(1.0)
  countsInCapacity  Boolean   @default(true)
  status            String    @default("active")
  activeFrom        DateTime  @default(now())
  activeTo          DateTime?
  absences          Absence[]
}

model Sprint {
  id            String          @id @default(cuid())
  team          Team            @relation(fields: [teamId], references: [id])
  teamId        String
  label         String
  quarter       String
  startDate     DateTime
  endDate       DateTime
  status        String          @default("planned")
  sprintGoal    String?
  capacityDays  Float?
  pctBau        Float           @default(0.30)
  pctRisk       Float           @default(0.10)
  pctCerem      Float           @default(0)
  pctOther      Float           @default(0)
  teamMood      Int?
  durationWeeks       Int?     @default(3)
  items         SprintItem[]
  burndown      BurndownEntry[]
  absences      Absence[]
}

model SprintItem {
  id           String   @id @default(cuid())
  sprint       Sprint   @relation(fields: [sprintId], references: [id])
  sprintId     String
  jiraKey      String?
  title        String
  type         String
  scope        String
  storyPoints  Int?
  status       String   @default("todo")
  isAdded      Boolean  @default(false)
  isRemoved    Boolean  @default(false)
  addedDay     Int?
  createdAt    DateTime @default(now())
}

model BurndownEntry {
  id          String   @id @default(cuid())
  sprint      Sprint   @relation(fields: [sprintId], references: [id])
  sprintId    String
  dayNumber   Int
  date        DateTime
  remainingSp Int?
  doneSp      Int?
  addedSp     Int      @default(0)
  removedSp   Int      @default(0)
  scopeTotal  Int?
}

model Absence {
  id         String   @id @default(cuid())
  member     Member   @relation(fields: [memberId], references: [id])
  memberId   String
  sprint     Sprint   @relation(fields: [sprintId], references: [id])
  sprintId   String
  type       String
  daysCount  Float
}
